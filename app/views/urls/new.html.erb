<div class="max-w-md mx-auto mt-12 bg-white p-8 border border-gray-200 rounded-xl shadow-sm">
  <div class="text-center mb-8">
    <h2 class="text-2xl font-bold text-gray-900">Shorten a URL</h2>
    <p class="mt-2 text-sm text-gray-500">Enter your long URL below to create a clean, short link.</p>
  </div>

  <%= form_with(model: @url, local: true, class: "space-y-6") do |form| %>
    <% if @url.errors.any? %>
      <div class="rounded-md bg-red-50 p-4 border border-red-200">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= pluralize(@url.errors.count, "error") %> prohibited this URL from being saved:</h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @url.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= form.label :original_url, "Original URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <div class="mt-1 relative rounded-md shadow-sm">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <span class="text-gray-500 sm:text-sm">🔗</span>
        </div>
        <%= form.text_field :original_url, class: "focus:ring-indigo-500 focus:border-indigo-500 block w-full pl-10 sm:text-sm border-gray-300 rounded-md py-3", placeholder: "https://example.com/very/long/path" %>
      </div>
    </div>

    <div>
      <%= form.label :short_code, "Custom Slug (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <div class="mt-1 flex rounded-md shadow-sm">
        <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 bg-gray-50 text-gray-500 sm:text-sm">
          <%= request.base_url %>/
        </span>
        <%= form.text_field :short_code, class: "focus:ring-indigo-500 focus:border-indigo-500 flex-1 block w-full rounded-none rounded-r-md sm:text-sm border-gray-300 py-3", placeholder: "my-custom-slug" %>
      </div>
    </div>

    <div>
      <%= form.submit "Shorten URL", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center">
    <%= link_to "← Back to Dashboard", urls_path, class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
  </div>
</div>
